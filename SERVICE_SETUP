# 安装 systemd 服务
sudo cp luckapi-backend.service /etc/systemd/system/
sudo systemctl daemon-reload
sudo systemctl enable luckapi-backend

# 检查服务状态
sudo systemctl status luckapi-backend

# 查看日志
sudo journalctl -u luckapi-backend -f

# 启动/停止/重启
sudo systemctl start luckapi-backend
sudo systemctl stop luckapi-backend
sudo systemctl restart luckapi-backend
